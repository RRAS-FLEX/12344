{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "typeRoots": [".", "./../node_modules/@types"],
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["deno"]
  },
  "include": ["**/*.ts"]
}
